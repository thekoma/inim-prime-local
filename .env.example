# Copy to .env (gitignored) and fill in your panel details.
INIM_HOST=192.168.1.x
INIM_PORT=8080
INIM_APIKEY=your-api-key-here
INIM_USE_HTTPS=false
# Optional: panel LAN password (default 'pass'). When set, the E2E also exercises
# the read-only local protocol (TCP 6004) and the multi-active scene sensors.
INIM_LOCAL_PASSWORD=
